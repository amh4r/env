{
	"statusLine": {
		"type": "command",
		"command": "bash ~/.claude/statusline.sh"
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowedDomains": ["api.github.com"],
			"allowLocalBinding": true
		},

    // Enabled to make the gh CLI work. Without it, there were cert errors in
    // Claude's sandbox
		"enableWeakerNetworkIsolation": true,

		"filesystem": {
			"allowWrite": ["~/Library/Caches/go-build"]
		}
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/usr/bin/osascript -e 'display notification \"👋\" with title \"Claude\"'"
					}
				]
			}
		]
	}
}
