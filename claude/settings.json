{
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/usr/bin/osascript -e 'display notification \"👋\" with title \"Claude\"'"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bash ~/.claude/statusline.sh"
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowedDomains": ["api.github.com"],
			"allowLocalBinding": true
		},
		"filesystem": {
			"allowWrite": ["~/Library/Caches/go-build", "~/.cache/uv"]
		},
		"enableWeakerNetworkIsolation": true
	},
	"env": {
		"UV_NO_SYNC": "1"
	},
	"enabledPlugins": {
		"typescript-lsp@claude-plugins-official": true
	}
}
