{
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/usr/bin/osascript -e 'display notification \"👋\" with title \"Claude\"'"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bash ~/.claude/statusline.sh"
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowedDomains": ["api.github.com"],
			"allowLocalBinding": true
		},
		"filesystem": {
			"allowWrite": ["~/Library/Caches/go-build", "~/.cache/uv", "~/.npm"]
		},
		"enableWeakerNetworkIsolation": true
	},
	"env": {
		"UV_NO_SYNC": "1",
		"DISABLE_TELEMETRY": "1",
		"DISABLE_ERROR_REPORTING": "1",
		"CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
	},
	"permissions": {
		"deny": [
			"Bash(rm -rf *)",
			"Bash(rm -fr *)",
			"Bash(sudo *)",
			"Bash(mkfs *)",
			"Bash(dd *)",
			"Bash(wget *|bash*)",
			"Bash(wget *| bash*)",
			"Bash(git push --force*)",
			"Bash(git push *--force*)",
			"Bash(git reset --hard*)",
			"Edit(~/.bashrc)",
			"Edit(~/.zshrc)",
			"Edit(~/.ssh/**)",
			"Read(~/.ssh/**)",
			"Read(~/.gnupg/**)",
			"Read(~/.aws/**)",
			"Read(~/.azure/**)",
			"Read(~/.config/gh/**)",
			"Read(~/.git-credentials)",
			"Read(~/.docker/config.json)",
			"Read(~/.kube/**)",
			"Read(~/.pypirc)",
			"Read(~/.gem/credentials)",
			"Read(~/Library/Keychains/**)",
			"Read(~/Library/Application Support/**/metamask*/**)",
			"Read(~/Library/Application Support/**/electrum*/**)",
			"Read(~/Library/Application Support/**/exodus*/**)",
			"Read(~/Library/Application Support/**/phantom*/**)",
			"Read(~/Library/Application Support/**/solflare*/**)"
		]
	},
	"enabledPlugins": {
		"typescript-lsp@claude-plugins-official": true
	}
}
